{
  "enabled": true,
  "name": "mystorageaccount",
  "resource_group_name": "rg-storage-dev",
  "location": "eastus",
  "account_tier": "Standard",
  "account_replication_type": "LRS",
  "is_hns_enabled": true,
  "public_network_access_enabled": false,
  "network_rules": {
    "default_action": "Deny",
    "bypass": ["AzureServices"],
    "vnet_key": "my-vnet",
    "subnet_names": ["snet-private-endpoints"],
    "ip_rules": [],
    "comment": "vnet_key and subnet_names are resolved to actual subnet IDs"
  },
  "containers": [
    {
      "name": "data",
      "container_access_type": "private"
    }
  ],
  "access_connector_key": "my-access-connector",
  "_related_resources": {
    "private_endpoints": ["my-storage-dfs-pe", "my-storage-blob-pe"],
    "dns_zones": ["storage-dfs-dns", "storage-blob-dns"],
    "comment": "These keys reference related resources in resources/azure/private_endpoints/ and resources/azure/private_dns_zones/. For documentation only - doesn't affect Terraform."
  },
  "tags": {
    "environment": "dev",
    "managed_by": "terraform"
  }
}
