{
  "enabled": true,
  "name": "sjstorageacc",
  "resource_group_name": "testTerraform",
  "location": "eastus",
  "account_tier": "Standard",
  "account_replication_type": "LRS",
  "is_hns_enabled": true,
  "public_network_access_enabled": true,
  "network_rules": {
    "default_action": "Deny",
    "bypass": ["AzureServices"],
    "vnet_key": "sjvnet",
    "subnet_names": ["snet-private-endpoint-pe-workspace"],
    "comment": "Network access restricted to private endpoints and specified subnets. AzureServices bypass allows trusted Azure services like Databricks."
  },
  "containers": [
    {
      "name": "metastore",
      "container_access_type": "private"
    },
    {
      "name": "external-data",
      "container_access_type": "private"
    },
    {
      "name": "checkpoints",
      "container_access_type": "private"
    }
  ],
  "access_connector_key": "sjaccesscon",
  "_related_resources": {
    "private_endpoints": ["sjstorageacc-dfs-pe", "sjstorageacc-blob-pe"],
    "dns_zones": ["storage-dfs-dns", "storage-blob-dns"],
    "comment": "These keys reference related resources for documentation. They don't affect Terraform behavior."
  },
  "tags": {
    "environment": "prod",
    "project": "databricks",
    "purpose": "unity-catalog",
    "data_classification": "confidential"
  }
}
