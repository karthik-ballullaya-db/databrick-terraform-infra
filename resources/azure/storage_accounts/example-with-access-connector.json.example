{
  "enabled": true,
  "name": "stdatabricksdev001",
  "resource_group_name": "rg-databricks-dev",
  "location": "eastus",
  "account_tier": "Standard",
  "account_replication_type": "LRS",
  "is_hns_enabled": true,
  "public_network_access_enabled": false,
  "network_rules": {
    "default_action": "Deny",
    "bypass": ["AzureServices", "Logging", "Metrics"],
    "vnet_key": "my-vnet",
    "subnet_names": ["snet-private-endpoints"],
    "comment": "Allow access from specified subnets. vnet_key and subnet_names are resolved to actual subnet IDs."
  },
  "containers": [
    {
      "name": "metastore",
      "container_access_type": "private"
    },
    {
      "name": "data",
      "container_access_type": "private"
    }
  ],
  "access_connector_key": "ac-databricks-dev",
  "_related_resources": {
    "private_endpoints": ["stdatabricksdev001-dfs-pe", "stdatabricksdev001-blob-pe"],
    "dns_zones": ["storage-dfs-dns", "storage-blob-dns"],
    "comment": "Create these resources in resources/azure/private_endpoints/ and resources/azure/private_dns_zones/"
  },
  "tags": {
    "environment": "dev",
    "project": "databricks",
    "purpose": "unity-catalog"
  }
}
